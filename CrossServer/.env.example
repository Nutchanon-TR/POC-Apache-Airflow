CT2_INPUT_PATH=/opt/airflow/shared/ct2-in/mock.txt
CT2_REVERSED_OUTPUT_PATH=/opt/airflow/shared/ct2-out/mock_reversed.txt

REQUEST_TIMEOUT_SECONDS=30
