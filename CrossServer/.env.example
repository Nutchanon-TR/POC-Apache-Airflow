AIRFLOW_UID=50000

# CT1 Airflow credentials
CT1_AIRFLOW_USER=airflow
CT1_AIRFLOW_PASSWORD=airflow

# CT2 Airflow credentials
CT2_AIRFLOW_USER=airflow
CT2_AIRFLOW_PASSWORD=airflow

# Shared volume paths (used by original docker-compose.yml)
CT1_OUTPUT_DIR=/opt/airflow/shared/ct1-out
CT1_DEFAULT_SOURCE_PATH=/opt/airflow/shared/ct1-out/Mock_latest.txt
CT2_DAG_ID=ct2_pipeline
CT2_INPUT_PATH=/opt/airflow/shared/ct2-in/mock.txt
CT2_REVERSED_OUTPUT_PATH=/opt/airflow/shared/ct2-out/mock_reversed.txt

# Worker service URLs
# WORKER_API_URL points to ct2-worker-api (used by CT1 to trigger CT2)
WORKER_API_URL=http://ct2-worker-api:9092
WORKER_BATCH_URL=http://worker-batch:9091

REQUEST_TIMEOUT_SECONDS=30

# Azure Blob Storage
# Storage account: crossserverpocsa  |  Container: crossserver-files
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;EndpointSuffix=core.windows.net;AccountName=crossserverpocsa;AccountKey=<YOUR_KEY>
AZURE_BLOB_CONTAINER=crossserver-files
