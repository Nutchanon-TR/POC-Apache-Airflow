AIRFLOW_UID=50000

CT1_AIRFLOW_USER=airflow
CT1_AIRFLOW_PASSWORD=airflow
CT2_AIRFLOW_URL=http://ct2-webserver:8080
CT2_AIRFLOW_USER=airflow
CT2_AIRFLOW_PASSWORD=airflow

CT1_OUTPUT_DIR=/opt/airflow/shared/ct1-out
CT1_DEFAULT_SOURCE_PATH=/opt/airflow/shared/ct1-out/Mock_latest.txt
