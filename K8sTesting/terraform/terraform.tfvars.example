# Copy to terraform.tfvars and tweak if needed. All values have sane defaults.

# subscription_id     = "59c0dcd7-abab-419f-808d-e6b1c11aa6ef"
# location            = "southeastasia"
# resource_group_name = "k8s-airflow-poc-rg"
