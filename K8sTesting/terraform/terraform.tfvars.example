# auto_stop_hours     = 4

# git-sync source for DAGs (must be reachable from AKS; public repo = no auth)
# git_repo_url = "https://github.com/Nutchanon-TR/POC-Apache-Airflow.git"
# git_branch   = "main"
# git_subpath  = "K8sTesting/dags"
